@model Account
@using Microsoft.AspNetCore.Hosting
@using Microsoft.Extensions.Hosting
@inject IWebHostEnvironment Env

@{
    ViewData["Title"] = "Logga in";
    // Genom att ta bort 'Layout = null' laddas nu din _Layout automatiskt
    // med Bootstrap, din meny och din nya globala site.css!
}

<div class="container mt-5 mb-5 align-content-center" style="min-height: 70vh;">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5 col-xl-4">
            
            <div class="text-center mb-4">
                <i class="bi bi-archive text-dark icon-xl"></i>
                <h2 class="fw-bold text-dark mt-3">Välkommen tillbaka</h2>
                <p class="text-muted small">Logga in för att komma åt katalogen och dina sidor.</p>
            </div>

            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4 p-md-5">

                    <form asp-route-returnurl="@ViewBag.ReturnUrl" method="post">

                        <div class="mb-4">
                            <label asp-for="Username" class="form-label fw-bold text-secondary small text-uppercase tracking-medium">Användarnamn</label>
                            <input asp-for="Username" class="form-control bg-light border-0 px-3 py-2 rounded-3" placeholder="Ange användarnamn..." required/>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label fw-bold text-secondary small text-uppercase tracking-medium">Lösenord</label>
                            <input asp-for="Password" type="password" class="form-control bg-light border-0 px-3 py-2 rounded-3" placeholder="••••••••" required/>
                        </div>

                        <button type="submit" class="btn btn-dark w-100 rounded-pill py-2 fw-bold shadow-sm mt-2">
                            <i class="bi bi-box-arrow-in-right me-2"></i> Logga in
                        </button>

                    </form>

                    @if (Env.IsDevelopment())
                    {
                        <div class="mt-4 pt-4 border-top">
                            <div class="text-muted small text-uppercase fw-bold mb-3 text-center tracking-medium">
                                Snabb-inloggning (Utveckling)
                            </div>
                            <div class="d-flex gap-2">
                                <form asp-action="QuickAdminLogin" method="post" class="w-50 m-0">
                                    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl"/>
                                    <button type="submit" class="btn btn-outline-danger w-100 rounded-pill btn-sm fw-bold">
                                        <i class="bi bi-shield-lock me-1"></i> Admin
                                    </button>
                                </form>

                                <form asp-action="QuickUserLogin" method="post" class="w-50 m-0">
                                    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl"/>
                                    <button type="submit" class="btn btn-outline-primary w-100 rounded-pill btn-sm fw-bold">
                                        <i class="bi bi-person me-1"></i> Användare
                                    </button>
                                </form>
                            </div>
                        </div>
                    }

                </div>
            </div>

        </div>
    </div>
</div>