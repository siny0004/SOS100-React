@model IEnumerable<SOS100_MVC.Models.Item>

@{
    ViewData["Title"] = "Katalogen";
}

<div class="container-fluid">

    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center mb-4 gap-3">
        <div>
            <h2 class="fw-bold mb-0 text-dark">Katalogen</h2>
        </div>

        @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
        {
        <div class="card shadow-sm border-0 bg-light rounded-4">
            <div class="card-body d-flex flex-wrap align-items-center p-2 px-3 gap-3">
                <div class="d-none d-xl-block">
                    <i class="bi bi-shield-lock-fill text-primary fs-5 me-1 align-middle"></i>
                    <span class="fw-bold text-dark small text-uppercase tracking-medium">Admin</span>
                </div>
               
                <div class="d-flex flex-wrap gap-2 align-items-center">
                    <form asp-controller="Catalog" asp-action="ClearCatalog" method="post" class="m-0" onsubmit="return confirm('VARNING! Är du helt säker på att du vill radera ALLA prylar i databasen?');">
                        <button type="submit" class="btn btn-outline-danger btn-sm fw-medium rounded-pill">
                            <i class="bi bi-trash3 me-1"></i> Rensa databasen
                        </button>
                    </form>

                    <form asp-controller="Catalog" asp-action="SeedCatalog" method="post" class="m-0">
                        <button type="submit" class="btn btn-success btn-sm fw-medium rounded-pill shadow-sm">
                            <i class="bi bi-magic me-1"></i> Fyll med testdata
                        </button>
                    </form>

                    <div class="vr mx-1 text-secondary d-none d-md-block"></div>

                    <a asp-action="Create" class="btn btn-primary btn-sm shadow-sm rounded-pill px-3 fw-medium">
                        <i class="bi bi-plus-lg me-1"></i> Nytt objekt
                    </a>
                </div>
            </div>
        </div>
        }
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
    <div class="alert alert-success shadow-sm rounded-3 mb-4 fw-medium">
        <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
    </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
    <div class="alert alert-danger shadow-sm rounded-3 mb-4 fw-medium">
        <i class="bi bi-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
    </div>
    }

    <div class="card border-0 shadow-sm rounded-4 mb-4 bg-white">
        <div class="card-body p-3 d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">

            <div class="input-group input-group-sm rounded-pill overflow-hidden bg-light border flex-grow-1 search-bar-mw">
                <span class="input-group-text bg-transparent border-0 pe-2"><i class="bi bi-search text-muted"></i></span>
                <input type="text" id="searchInput" class="form-control border-0 bg-transparent py-2 px-1 shadow-none" placeholder="Sök på namn, plats...">
            </div>

            <div class="d-flex flex-wrap gap-2 justify-content-center">
                <input type="checkbox" class="btn-check category-filter" id="cat-elektronik" value="Elektronik">
                <label class="btn filter-btn rounded-pill px-3 py-1 fw-medium text-sm" for="cat-elektronik"><i class="bi bi-laptop me-1"></i> Elektronik</label>

                <input type="checkbox" class="btn-check category-filter" id="cat-bok" value="Bok">
                <label class="btn filter-btn rounded-pill px-3 py-1 fw-medium text-sm" for="cat-bok"><i class="bi bi-book me-1"></i> Bok</label>

                <input type="checkbox" class="btn-check category-filter" id="cat-rapport" value="Rapport">
                <label class="btn filter-btn rounded-pill px-3 py-1 fw-medium text-sm" for="cat-rapport"><i class="bi bi-file-earmark-text me-1"></i> Rapport</label>

                <input type="checkbox" class="btn-check category-filter" id="cat-annat" value="Annat">
                <label class="btn filter-btn rounded-pill px-3 py-1 fw-medium text-sm" for="cat-annat"><i class="bi bi-box-seam me-1"></i> Annat</label>
            </div>

            <div class="vr text-secondary opacity-25 d-none d-lg-block mx-1"></div>

            <div class="form-check form-switch mb-0 d-flex align-items-center justify-content-lg-end">
                <input class="form-check-input m-0 border-secondary shadow-sm cursor-pointer" type="checkbox" role="switch" id="availableOnlyCheck">
                <label class="form-check-label text-muted fw-bold small ms-2 text-uppercase mt-1 cursor-pointer tracking-medium" for="availableOnlyCheck">
                    Visa endast tillgängliga
                </label>
            </div>

        </div>
    </div>

    <div class="table-container shadow-sm border-0 mb-4">
        <table class="table mb-0 align-middle">
            <thead>
            <tr>
                <th>Namn</th>
                <th>Kategori</th>
                <th>Plats</th>
                <th>Status</th>
                <th class="text-end">Åtgärder</th>
            </tr>
            </thead>
            <tbody id="tableBody">
            @foreach (var item in Model)
            {
                string statusClass = item.Status switch
                {
                    SOS100_MVC.Models.ItemStatus.Tillgänglig => "badge-green",
                    SOS100_MVC.Models.ItemStatus.Utlånad => "badge-yellow",
                    SOS100_MVC.Models.ItemStatus.Trasig => "badge-red",
                    _ => "badge-gray"
                };
            
            string typeIcon = item.Type switch
            {
            SOS100_MVC.Models.ItemType.Bok => "bi-book",
            SOS100_MVC.Models.ItemType.Elektronik => "bi-laptop",
            SOS100_MVC.Models.ItemType.Rapport => "bi-file-earmark-text",
            _ => "bi-box-seam"
            };

            <tr data-status="@item.Status" data-type="@item.Type">
                <td class="fw-bold">
                    <a asp-action="Details" asp-route-id="@item.Id" class="text-dark text-decoration-none" title="Visa detaljer">
                        @item.Name
                    </a>
                </td>
                <td>
                    <i class="bi @typeIcon fs-5 me-2 text-muted"></i>
                    @item.Type
                </td>
                <td class="fw-medium text-dark">@item.Placement</td>
                <td>
                    <span class="status-badge @statusClass">@item.Status</span>
                </td>
                <td class="text-end">
                    <div class="d-flex justify-content-end gap-2">
                        @if (item.Status == SOS100_MVC.Models.ItemStatus.Utlånad && User.Identity.IsAuthenticated)
                        {
                        <form asp-controller="Catalog" asp-action="AddWatch" method="post" class="m-0">
                            <input type="hidden" name="itemId" value="@item.Id" />
                            <input type="hidden" name="itemTitle" value="@item.Name" />
                            <button type="submit" class="btn btn-sm btn-outline-warning shadow-sm rounded-circle" title="Bevaka detta objekt">
                                <i class="bi bi-bell"></i>
                            </button>
                        </form>
                        }

                        @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                        {
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger shadow-sm rounded-circle" title="Ta bort">
                            <i class="bi bi-x-lg"></i>
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary shadow-sm rounded-circle" title="Redigera">
                            <i class="bi bi-pencil-square"></i>
                        </a>
                        }

                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary shadow-sm rounded-circle" title="Visa detaljer">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </div>
                </td>
            </tr>
            }
            </tbody>
        </table>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="d-flex flex-wrap justify-content-end gap-4 mt-2 pe-2 small">
            <div><span class="text-muted text-uppercase tracking-medium" style="font-size: 10px;">Totalt:</span> <span class="fw-bold text-dark">@Model.Count()</span></div>
            <div><span class="text-muted text-uppercase tracking-medium" style="font-size: 10px;">Tillgängliga:</span> <span class="fw-bold text-success">@Model.Count(i => i.Status == SOS100_MVC.Models.ItemStatus.Tillgänglig)</span></div>
            <div><span class="text-muted text-uppercase tracking-medium" style="font-size: 10px;">Utlånade:</span> <span class="fw-bold text-warning">@Model.Count(i => i.Status == SOS100_MVC.Models.ItemStatus.Utlånad)</span></div>
            <div><span class="text-muted text-uppercase tracking-medium" style="font-size: 10px;">Trasiga/Saknas:</span> <span class="fw-bold text-danger">@Model.Count(i => i.Status == SOS100_MVC.Models.ItemStatus.Trasig || i.Status == SOS100_MVC.Models.ItemStatus.Saknas)</span></div>
        </div>
    }
    

</div>

@section Scripts {
<script>
    const searchInput = document.getElementById('searchInput');
    const availableOnlyCheck = document.getElementById('availableOnlyCheck');
    const categoryFilters = document.querySelectorAll('.category-filter');
    const rows = document.querySelectorAll('#tableBody tr');

    function filterTable() {
        if(!searchInput) return;

        const filterText = searchInput.value.toLowerCase();
        const showOnlyAvailable = availableOnlyCheck.checked;
        const selectedCategories = Array.from(categoryFilters)
            .filter(cb => cb.checked)
            .map(cb => cb.value);

        rows.forEach(row => {
            const rowText = row.textContent.toLowerCase();
            const rowStatus = row.getAttribute('data-status');
            const rowType = row.getAttribute('data-type');

            const matchesText = rowText.includes(filterText);
            const matchesStatus = showOnlyAvailable ? rowStatus === 'Tillgänglig' : true;
            const matchesCategory = selectedCategories.length === 0 || selectedCategories.includes(rowType);

            if (matchesText && matchesStatus && matchesCategory) {
                row.style.display = "";
            } else {
                row.style.display = "none";
            }
        });
    }

    if(searchInput) {
        searchInput.addEventListener('input', filterTable);
        availableOnlyCheck.addEventListener('change', filterTable);
        categoryFilters.forEach(cb => cb.addEventListener('change', filterTable));
    }
</script>
}