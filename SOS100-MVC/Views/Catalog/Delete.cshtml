@model SOS100_MVC.Models.Item

@{
    ViewData["Title"] = "Ta bort " + Model.Name;

    string typeIcon = Model.Type switch
    {
        SOS100_MVC.Models.ItemType.Bok => "bi-book",
        SOS100_MVC.Models.ItemType.Elektronik => "bi-laptop",
        SOS100_MVC.Models.ItemType.Rapport => "bi-file-earmark-text",
        _ => "bi-box-seam"
    };
}


<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            
            <div class="card shadow border-0 rounded-4 border-top border-danger border-4">
                
                <div class="card-body p-5 text-center">
                    
                    <div class="mb-4">
                        <i class="bi bi-exclamation-circle text-danger icon-xl"></i>
                    </div>
                    
                    <h2 class="fw-bold mb-3">Är du helt säker?</h2>
                    <p class="text-secondary fs-5 mb-4">
                        Du håller på att permanent ta bort <strong>@Model.Name</strong> från katalogen. Denna åtgärd går inte att ångra.
                    </p>
                    
                    <div class="bg-light p-4 rounded-4 text-start mb-4 shadow-sm border border-light">
                        <div class="d-flex align-items-center mb-3 text-muted">
                            <i class="bi @typeIcon fs-4 me-2"></i>
                            <span class="fw-bold text-uppercase tracking-wide">@Model.Type</span>
                        </div>
                        
                        <h4 class="fw-bold text-dark mb-2">@Model.Name</h4>
                        <p class="text-secondary small mb-3">@Model.Description</p>
                        
                        <hr class="text-muted opacity-25 my-3">
                        
                        <div class="row g-2 small text-muted fw-medium">
                            <div class="col-6">
                                <i class="bi bi-geo-alt me-1 text-primary"></i> @Model.Placement
                            </div>
                            <div class="col-6 text-end">
                                <i class="bi bi-calendar3 me-1 text-primary"></i> Inköpt: @Model.PurchaseDate.ToShortDateString()
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-center gap-3 mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 fw-bold">
                            Avbryt
                        </a>
                         
                        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="m-0">
                            <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm">
                                <i class="bi bi-trash3 me-2"></i> Ja, ta bort
                            </button>
                        </form>
                    </div>

                </div>
            </div>
            
        </div>
    </div>
</div>