@model SOS100_MVC.Models.Item

@{
    ViewData["Title"] = "Redigera " + Model.Name;
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            
            <div class="card shadow border-0 rounded-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-2 px-4">
                    <h3 class="mb-0 fw-bold d-flex align-items-center">
                        <i class="bi bi-pencil-square text-primary me-2"></i> Redigera objekt
                    </h3>
                    <p class="text-muted small mt-1 mb-0">Uppdatera informationen för <strong>@Model.Name</strong>.</p>
                </div>
              
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        
                        <input type="hidden" asp-for="Id" />
                         
                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold text-secondary small text-uppercase">Namn på objektet</label>
                            <input asp-for="Name" class="form-control bg-light border-0 px-3 py-2 rounded-3" required />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="Type" class="form-label fw-bold text-secondary small text-uppercase">Kategori</label>
                                <select asp-for="Type" class="form-select bg-light border-0 px-3 py-2 rounded-3" asp-items="Html.GetEnumSelectList<SOS100_MVC.Models.ItemType>()" required></select>
                                <span asp-validation-for="Type" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="Status" class="form-label fw-bold text-secondary small text-uppercase">Status</label>
                                <select asp-for="Status" class="form-select bg-light border-0 px-3 py-2 rounded-3" asp-items="Html.GetEnumSelectList<SOS100_MVC.Models.ItemStatus>()" required></select>
                                <span asp-validation-for="Status" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold text-secondary small text-uppercase">Beskrivning</label>
                            <textarea asp-for="Description" class="form-control bg-light border-0 px-3 py-2 rounded-3" rows="3"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="Placement" class="form-label fw-bold text-secondary small text-uppercase">Plats / Förvaring</label>
                                <input asp-for="Placement" class="form-control bg-light border-0 px-3 py-2 rounded-3" />
                                <span asp-validation-for="Placement" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="PurchaseDate" class="form-label fw-bold text-secondary small text-uppercase">Inköpsdatum</label>
                                <input asp-for="PurchaseDate" class="form-control bg-light border-0 px-3 py-2 rounded-3" type="date" required />
                                <span asp-validation-for="PurchaseDate" class="text-danger small"></span>
                            </div>
                        </div>

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                        <div class="d-flex justify-content-between align-items-center mt-2 pt-3 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                                <i class="bi bi-x-circle me-1"></i> Avbryt
                            </a>
                            <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                                <i class="bi bi-save me-1"></i> Spara ändringar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
            
        </div>
    </div>
</div>