@model SOS100_MVC.Models.Item

@{
    ViewData["Title"] = "Låna: " + Model.Name;
    var borrowerId = User?.Identity?.Name ?? "";

    // Samma badge-logik som på detaljsidan
    string statusClass = Model.Status switch
    {
        SOS100_MVC.Models.ItemStatus.Tillgänglig => "badge-green",
        SOS100_MVC.Models.ItemStatus.Utlånad => "badge-yellow",
        SOS100_MVC.Models.ItemStatus.Trasig => "badge-red",
        _ => "badge-gray"
    };

    // Ikon baserat på typ
    string typeIcon = Model.Type switch
    {
        SOS100_MVC.Models.ItemType.Bok => "bi-book",
        SOS100_MVC.Models.ItemType.Elektronik => "bi-laptop",
        SOS100_MVC.Models.ItemType.Rapport => "bi-file-earmark-text",
        _ => "bi-box-seam"
    };
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">

            <div class="d-flex align-items-center mb-4">
                <a asp-controller="Catalog" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-light border-0 shadow-sm rounded-circle p-2 me-3" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-arrow-left fs-5"></i>
                </a>
                <div>
                    <h2 class="fw-bold mb-0 text-dark">Bekräfta lån</h2>
                    <p class="text-muted small mt-1 mb-0">Slutför din låneförfrågan för vald artikel.</p>
                </div>
            </div>

            <div class="card shadow-sm border-0 rounded-4 bg-white">
                <div class="card-body p-4 p-md-5">

                    <div class="d-flex justify-content-between align-items-start pb-4 mb-4 border-bottom">
                        <div class="d-flex align-items-center">
                            <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                                <i class="bi @typeIcon fs-3"></i>
                            </div>
                            <div>
                                <h4 class="fw-bold mb-1 text-dark">@Model.Name</h4>
                                <div class="text-muted small">System-ID: #@Model.Id &bull; Kategori: @Model.Type</div>
                            </div>
                        </div>
                        <span class="status-badge @statusClass fs-6">
                            @Model.Status
                        </span>
                    </div>

                    <div class="mb-4">
                        <h6 class="text-muted text-uppercase tracking-wide fw-bold mb-2 small">Beskrivning & Förvaring</h6>
                        <p class="text-secondary lh-relaxed mb-2">@Model.Description</p>
                        <p class="text-secondary small mb-0"><i class="bi bi-geo-alt text-primary me-1"></i> <strong>Plats:</strong> @Model.Placement</p>
                    </div>

                    @if (Model.Status != SOS100_MVC.Models.ItemStatus.Tillgänglig)
                    {
                        <div class="alert alert-warning border-0 rounded-3 shadow-sm d-flex align-items-center mb-4">
                            <i class="bi bi-exclamation-triangle-fill fs-4 me-3 text-warning"></i>
                            <div>
                                Den här prylen är inte markerad som <strong>Tillgänglig</strong> i katalogen.<br>
                                <span class="small opacity-75">Låneförsök kan stoppas av LoanAPI (Conflict).</span>
                            </div>
                        </div>
                    }

                    @if (TempData["LoanError"] != null)
                    {
                        <div class="alert alert-danger border-0 rounded-3 shadow-sm d-flex align-items-center mb-4">
                            <i class="bi bi-x-octagon-fill fs-4 me-3 text-danger"></i>
                            <div>@TempData["LoanError"]</div>
                        </div>
                    }

                    <form asp-controller="Loan" asp-action="Create" method="post" class="mt-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="ItemId" value="@Model.Id" />

                        <div class="row g-4 mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-secondary small text-uppercase">Låntagare</label>
                                <div class="input-group shadow-sm rounded-3">
                                    <span class="input-group-text bg-light border-0 text-muted"><i class="bi bi-person"></i></span>
                                    <input class="form-control bg-light border-0 px-3 py-2 text-muted" name="BorrowerId" value="@borrowerId" readonly />
                                </div>
                                <div class="form-text small mt-2">Hämtas automatiskt från din inloggning.</div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold text-secondary small text-uppercase">Antal lånedagar (1–60)</label>
                                <div class="input-group shadow-sm rounded-3">
                                    <span class="input-group-text bg-light border-0 text-muted"><i class="bi bi-calendar-event"></i></span>
                                    <input class="form-control bg-light border-0 px-3 py-2 fw-bold" type="number" name="LoanDays" value="14" min="1" max="60" required />
                                </div>
                                <div class="form-text small mt-2">Standardlån är 14 dagar.</div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end align-items-center pt-3 mt-4 border-top">
                            <button type="submit" class="btn btn-success px-4 py-2 rounded-pill shadow-sm fw-bold" @(Model.Status == SOS100_MVC.Models.ItemStatus.Tillgänglig ? "" : "disabled")>
                                <i class="bi bi-check2-circle me-1"></i> Bekräfta lån
                            </button>
                        </div>
                    </form>

                </div>
            </div>
            
            <div class="text-center mt-3 text-muted small opacity-50">
                <i class="bi bi-shield-lock me-1"></i> Lånet skapas säkert via LoanAPI
            </div>

        </div>
    </div>
</div>