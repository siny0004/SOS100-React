@model SOS100_MVC.Models.User?
@using SOS100_MVC.Models
@using SOS100_MVC.Dtos

@{
    ViewData["Title"] = "Mina sidor";
    var reminders = ViewBag.Reminders as List<Reminder> ?? new List<Reminder>();
    var watches = ViewBag.Watches as List<Watch> ?? new List<Watch>();
    var activeLoans = ViewBag.ActiveLoans as List<LoanDto> ?? new List<LoanDto>();
}

<div class="container-fluid">

    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center mb-4 gap-3">
        <div>
            <h2 class="fw-bold mb-0 text-dark">Mina sidor</h2>
            @if (Model != null)
            {
                <p class="text-muted small mt-1 mb-0">@Model.FirstName @Model.LastName</p>
            }
        </div>
    </div>
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success shadow-sm rounded-3 mb-4 fw-medium">
            <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
        </div>
    }
    <div class="row g-4">

        <div class="col-12">
            <h4 class="fw-bold mb-3 text-dark fs-5 d-flex align-items-center">
                <i class="bi bi-clock-history text-primary me-2 fs-4"></i> Aktiva lån
            </h4>
            @if (!activeLoans.Any())
            {
                <div class="bg-white border rounded-4 p-4 text-center text-muted small shadow-sm">
                    Inga aktiva lån just nu.
                </div>
            }
            else
            {
                <div class="table-container shadow-sm border-0">
                    <table class="table mb-0 align-middle">
                        <thead>
                            <tr>
                                <th>Objekt</th>
                                <th>Lånat</th>
                                <th>Förfaller</th>
                                <th>Status</th>
                                <th class="text-end">ÅTGÄRDER</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var loan in activeLoans)
                            {
                                var daysLeft = (loan.DueAt - DateTimeOffset.Now).Days;
                                var isOverdue = loan.DueAt < DateTimeOffset.Now;
                                string loanBadgeClass = isOverdue ? "badge-red" : daysLeft <= 3 ? "badge-yellow" : "badge-green";
                                
                                <tr>
                                    <td class="fw-bold">
                                        <a asp-controller="Catalog" asp-action="Details" asp-route-id="@loan.ItemId" class="text-dark text-decoration-none" title="Visa detaljer">
                                            @loan.ItemName
                                        </a>
                                    </td>
                                    <td>@loan.LoanedAt.ToString("yy-MM-dd")</td>
                                    <td>@loan.DueAt.ToString("yy-MM-dd")</td>
                                    <td>
                                        <span class="status-badge @loanBadgeClass">
                                            @(isOverdue ? $"{Math.Abs(daysLeft)} dagar sen" : $"{daysLeft} dagar kvar")
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <form asp-controller="MyPages" asp-action="ReturnItem" method="post" class="m-0">
                                            <input type="hidden" name="loanId" value="@loan.Id"/>
                                            <input type="hidden" name="userId" value="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value"/>
                                            <button type="submit" class="btn btn-sm btn-outline-primary shadow-sm rounded-circle" title="Återlämna">
                                                <i class="bi bi-arrow-return-left"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

<div class="col-12 mt-5">
            <h4 class="fw-bold mb-3 text-dark fs-5 d-flex align-items-center">
                <i class="bi bi-bell text-dark me-2 fs-4"></i> Bevakningar
            </h4>
            @if (!watches.Any())
            {
                <div class="bg-white border rounded-4 p-4 text-center text-muted small shadow-sm">
                    Inga bevakningar just nu.
                </div>
            }
            else
            {
                <div class="table-container shadow-sm border-0">
                    <table class="table mb-0 align-middle">
                        <thead>
                            <tr>
                                <th>Objekt</th>
                                <th>Status</th>
                                <th class="text-end">ÅTGÄRDER</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var w in watches)
                            {
                                string watchBadgeClass = w.IsActive ? "badge-green" : "badge-gray";
                                
                                <tr>
                                    <td class="fw-bold">
                                        <a asp-controller="Catalog" asp-action="Details" asp-route-id="@w.ItemId" class="text-dark text-decoration-none" title="Visa detaljer">
                                            @w.ItemTitle
                                        </a>
                                    </td>
                                    <td>
                                        <span class="status-badge @watchBadgeClass">
                                            @(w.IsActive ? "Tillgänglig" : "Bevakas")
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <form asp-controller="MyPages" asp-action="StopWatch" method="post" class="m-0">
                                            <input type="hidden" name="watchId" value="@w.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger shadow-sm rounded-circle" title="Sluta bevaka">
                                                <i class="bi bi-bell-slash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <div class="col-12 mt-5">
            <h4 class="fw-bold mb-3 text-dark fs-5 d-flex align-items-center">
                <i class="bi bi-alarm me-2 fs-4"></i> Mina påminnelser 
                <span class="badge bg-danger rounded-pill ms-2 fs-6">@reminders.Count(r => !r.IsSent)</span>
            </h4>
            
            @if (!reminders.Any(r => !r.IsSent))
            {
                <div class="bg-white border rounded-4 p-4 text-center text-muted small shadow-sm">
                    Inga påminnelser just nu.
                </div>
            }
            else
            {
                <div class="table-container shadow-sm border-0">
                    <table class="table mb-0 align-middle">
                        <thead>
                            <tr>
                                <th>Objekt</th>
                                <th>Förfaller</th>
                                <th>Tid kvar</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in reminders.Where(r => !r.IsSent))
                            {
                                var daysLeft = (r.DueDate - DateTime.Now).Days;
                                var isOverdue = r.DueDate < DateTime.Now;
                                string statusBadge = isOverdue ? "badge-red" : daysLeft <= 3 ? "badge-yellow" : "badge-green";
                                
                                <tr>
                                    <td class="fw-bold">
                                        <a asp-controller="Catalog" asp-action="Details" asp-route-id="@r.ItemId" class="text-dark text-decoration-none" title="Visa detaljer">
                                            @r.ItemTitle
                                        </a>
                                    </td>
                                    <td>@r.DueDate.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        <span class="status-badge @statusBadge">
                                            @(isOverdue ? $"{Math.Abs(daysLeft)} dagar sen" : $"{daysLeft} dagar kvar")
                                        </span>
                                    </td>
                                    <td>
                                        <span class="status-badge badge-yellow">
                                            <i class="bi bi-hourglass-split me-1"></i> Väntar
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

    </div>
</div>