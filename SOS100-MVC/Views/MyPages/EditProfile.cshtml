@model EditProfileViewModel

@{
    ViewData["Title"] = "Ändra uppgifter";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            
            <div class="card shadow border-0 rounded-4 mb-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-2 px-4">
                    <h3 class="mb-0 fw-bold d-flex align-items-center">
                        <i class="bi bi-person-gear text-primary me-2"></i> Ändra uppgifter 
                    </h3>
                </div>
                
                <div class="card-body p-4">
                    <form asp-action="EditProfile" method="post"> 
                        
                        <div class="mb-4">
                            <label asp-for="User.Username" class="form-label fw-bold text-secondary small text-uppercase">Användarnamn</label> 
                            <input asp-for="User.Username" class="form-control bg-light border-0 px-3 py-2 rounded-3" /> 
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label asp-for="User.FirstName" class="form-label fw-bold text-secondary small text-uppercase">Förnamn</label> 
                                <input asp-for="User.FirstName" class="form-control bg-light border-0 px-3 py-2 rounded-3" /> 
                            </div>
                            <div class="col-md-6">
                                <label asp-for="User.LastName" class="form-label fw-bold text-secondary small text-uppercase">Efternamn</label> 
                                <input asp-for="User.LastName" class="form-control bg-light border-0 px-3 py-2 rounded-3" /> 
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="User.Email" class="form-label fw-bold text-secondary small text-uppercase">E-postadress</label>
                            <input asp-for="User.Email" type="email" class="form-control bg-light border-0 px-3 py-2 rounded-3" />
                        </div>

                        <div class="d-flex justify-content-end mt-2 pt-3 border-top">
                            <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                                <i class="bi bi-save me-1"></i> Spara uppgifter
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card shadow border-0 rounded-4 mb-5 border-top border-warning border-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-2 px-4">
                    <h4 class="mb-0 fw-bold d-flex align-items-center">
                        <i class="bi bi-shield-lock text-warning me-2"></i> Hantera lösenord
                    </h4>
                </div>
                
                <div class="card-body p-4">
                    <form asp-action="EditPassword" method="post">
                        
                        <div class="mb-4">
                            <label asp-for="PasswordDto.Password" class="form-label fw-bold text-secondary small text-uppercase">Gammalt lösenord</label>
                            <input asp-for="PasswordDto.Password" type="password" class="form-control bg-light border-0 px-3 py-2 rounded-3" />
                        </div>

                        <div class="mb-4">
                            <label asp-for="PasswordDto.NewPassword" class="form-label fw-bold text-secondary small text-uppercase">Nytt lösenord</label>
                            <input asp-for="PasswordDto.NewPassword" type="password" class="form-control bg-light border-0 px-3 py-2 rounded-3" />
                        </div>

                        <div class="d-flex justify-content-end mt-2 pt-3 border-top">
                            <button type="submit" class="btn btn-warning rounded-pill px-4 fw-bold shadow-sm text-dark">
                                <i class="bi bi-key me-1"></i> Spara lösenord
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>