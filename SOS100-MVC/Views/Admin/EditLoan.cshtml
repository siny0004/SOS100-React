@model SOS100_MVC.Dtos.LoanDto

@{
    ViewData["Title"] = "Redigera lån";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            
            <div class="card shadow border-0 rounded-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-2 px-4">
                    <h3 class="mb-0 fw-bold d-flex align-items-center">
                        <i class="bi bi-calendar2-plus text-primary me-2"></i> Ändra lånetid
                    </h3>
                    <p class="text-muted small mt-1 mb-0">Förläng eller förkorta lånet för <strong>@Model.ItemName</strong>.</p>
                </div>
              
                <div class="card-body p-4">
                    
                    <div class="bg-light p-3 rounded-3 mb-4">
                        <div class="row text-muted small mb-2">
                            <div class="col-6 fw-bold text-uppercase">Låntagare</div>
                            <div class="col-6 text-end">@Model.BorrowerId</div>
                        </div>
                        <div class="row text-muted small">
                            <div class="col-6 fw-bold text-uppercase">Startdatum</div>
                            <div class="col-6 text-end">@Model.LoanedAt.ToString("yyyy-MM-dd")</div>
                        </div>
                    </div>

                    <form asp-action="EditLoan" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                         
                        <div class="mb-4">
                            <label for="dueAt" class="form-label fw-bold text-secondary small text-uppercase">Nytt förfallodatum</label>
                            <input type="date" id="dueAt" name="dueAt" value="@Model.DueAt.ToString("yyyy-MM-dd")" class="form-control bg-light border-0 px-3 py-2 rounded-3" required />
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-2 pt-3 border-top">
                            <a asp-action="Loans" class="btn btn-outline-secondary rounded-pill px-4">
                                <i class="bi bi-x-circle me-1"></i> Avbryt
                            </a>
                            <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                                <i class="bi bi-save me-1"></i> Spara nytt datum
                            </button>
                        </div>
                    </form>
                </div>
            </div>
            
        </div>
    </div>
</div>