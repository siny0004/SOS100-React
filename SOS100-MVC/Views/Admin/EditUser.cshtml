@model SOS100_MVC.Models.User

@{
    ViewData["Title"] = "Redigera användare";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            
            <div class="card shadow border-0 rounded-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-2 px-4">
                    <h3 class="mb-0 fw-bold d-flex align-items-center">
                        <i class="bi bi-pencil-square text-primary me-2"></i> Redigera användare
                    </h3>
                </div>
                
                <div class="card-body p-4">
                    <form asp-action="EditUser" method="post">
                        
                        <input type="hidden" asp-for="UserID" />
                        
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label asp-for="FirstName" class="form-label fw-bold text-secondary small text-uppercase">Förnamn</label>
                                <input asp-for="FirstName" class="form-control bg-light border-0 px-3 py-2 rounded-3" required />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="LastName" class="form-label fw-bold text-secondary small text-uppercase">Efternamn</label>
                                <input asp-for="LastName" class="form-control bg-light border-0 px-3 py-2 rounded-3" required />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Username" class="form-label fw-bold text-secondary small text-uppercase">Användarnamn</label>
                            <input asp-for="Username" class="form-control bg-light border-0 px-3 py-2 rounded-3" required />
                        </div>

                        <div class="mb-4">
                            <label asp-for="Email" class="form-label fw-bold text-secondary small text-uppercase">E-postadress</label>
                            <input asp-for="Email" type="email" class="form-control bg-light border-0 px-3 py-2 rounded-3" required />
                        </div>

                        <div class="mb-4">
                            <label asp-for="Role" class="form-label fw-bold text-secondary small text-uppercase">Behörighet (Roll)</label>
                            <select asp-for="Role" class="form-select bg-light border-0 px-3 py-2 rounded-3">
                                <option value="User">Standardanvändare (User)</option>
                                <option value="Admin">Administratör (Admin)</option>
                            </select>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-2 pt-3 border-top">
                            <a asp-action="Users" class="btn btn-outline-secondary rounded-pill px-4">
                                <i class="bi bi-x-circle me-1"></i> Avbryt
                            </a>
                            <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                                <i class="bi bi-save me-1"></i> Spara ändringar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
            
        </div>
    </div>
</div>