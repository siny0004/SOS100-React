@model List<SOS100_MVC.Dtos.UserDto>

@{
    ViewData["Title"] = "Hantera användare";
}

<div class="container-fluid">
    
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h2 class="fw-bold mb-0 text-dark">Användare</h2>
        </div>
        
        <a asp-controller="Admin" asp-action="CreateUser" class="btn btn-primary shadow-sm rounded-pill px-4 fw-medium">
            <i class="bi bi-person-plus me-2"></i> Skapa ny användare
        </a>
    </div>

    <div class="table-container shadow-sm border-0 mb-4">
        <table class="table mb-0 align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Användare</th>
                    <th>Kontakt</th>
                    <th>Roll</th>
                    <th class="text-end">Åtgärder</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="text-muted small fw-bold">#@user.UserID</td>
                        <td>
                            <div class="fw-bold text-dark">@user.FirstName @user.LastName</div>
                            <div class="small text-muted">@user.Username</div>
                        </td>
                        <td class="text-secondary">
                            <i class="bi bi-envelope me-1"></i> @user.Email
                        </td>
                        <td>
                            @{
                                string roleClass = user.Role == "Admin" ? "badge-red" : "badge-green";
                            }
                            <span class="status-badge @roleClass">@user.Role</span>
                        </td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-2">
                                <a asp-controller="Admin" asp-action="EditUser" asp-route-id="@user.UserID" class="btn btn-sm btn-outline-primary shadow-sm rounded-circle" title="Redigera">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                
                                <form asp-action="DeleteUser" asp-route-id="@user.UserID" method="post" class="m-0" onsubmit="return confirm('Är du helt säker på att du vill ta bort @user.FirstName?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger shadow-sm rounded-circle" title="Ta bort">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>